<UserControl x:Class="Meeting_Recorder.Views.Recorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,30,0,0">
            <TextBlock Text="Meeting Recorder"
                       Style="{StaticResource TitleTextStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="{Binding ElapsedTime}"
                       Style="{StaticResource TimerTextStyle}" />

            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource StatusTextStyle}"
                       Margin="0,12,0,30" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="● Record"
                        Style="{StaticResource RecordButtonStyle}"
                        Command="{Binding StartCommand}"
                        Margin="0,0,20,0" />

                <Button Content="■ Stop"
                        Style="{StaticResource StopButtonStyle}"
                        Command="{Binding StopCommand}"
                        Margin="20,0,0,0" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2"
                Background="{StaticResource SecondaryBrush}"
                Padding="16,10">
            <TextBlock Text="{Binding OutputFilePath, StringFormat='Output: {0}'}"
                       Foreground="{StaticResource SubtleTextBrush}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</UserControl>
